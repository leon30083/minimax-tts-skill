# MiniMax 国际站 TTS API 配置
# 获取 API Key: https://platform.minimax.io

# API Key（必填）
MINIMAX_API_KEY=your-api-key-here

# API 端点（默认）
MINIMAX_BASE_URL=https://api.minimax.io

# 默认模型
# speech-2.6-turbo: 快速、便宜
# speech-2.6-hd: 高质量、稍贵
DEFAULT_MODEL=speech-2.6-turbo

# 默认音频设置
DEFAULT_SAMPLE_RATE=32000
DEFAULT_BITRATE=128000
DEFAULT_FORMAT=mp3
DEFAULT_CHANNEL=1
